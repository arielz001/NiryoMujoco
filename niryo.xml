<mujoco model="niryo_ned2_con_garra">
    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 0"/>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="512" height="512"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 .05" type="plane" material="grid"/>

        <body name="base_link" pos="0 0 0">
            <geom name="base_geom" type="cylinder" size="0.08 0.05" pos="0 0 0.05" rgba="0.15 0.15 0.15 1"/>
            
            <body name="shoulder_link" pos="0 0 0.103">
                <joint name="joint_1" type="hinge" axis="0 0 1" range="-2.949 2.949"/>
                <geom type="cylinder" size="0.05 0.04" pos="0 0 0.04" rgba="0.9 0.9 0.9 1"/>
                
                <body name="arm_link" pos="0 0 0.08">
                    <joint name="joint_2" type="hinge" axis="0 1 0" range="-1.83 0.61"/>
                    <geom type="capsule" size="0.035" fromto="0 0 0 0 0 0.221" rgba="0.15 0.15 0.15 1"/>
                    
                    <body name="forearm_link" pos="0 0 0.221">
                        <joint name="joint_3" type="hinge" axis="0 1 0" range="-1.34 1.57"/>
                        <geom type="capsule" size="0.03" fromto="0 0 0 0.047 0 0.201" rgba="0.9 0.9 0.9 1"/>
                        
                        <body name="wrist_link" pos="0.047 0 0.201">
                            <joint name="joint_4" type="hinge" axis="1 0 0" range="-2.089 2.089"/>
                            <geom type="capsule" size="0.025" fromto="0 0 0 0.136 0 0" rgba="0.15 0.15 0.15 1"/>
                            
                            <body name="wrist_flex_link" pos="0.136 0 0">
                                <joint name="joint_5" type="hinge" axis="0 1 0" range="-1.919 1.922"/>
                                <geom type="cylinder" size="0.025 0.02" rgba="0.9 0.9 0.9 1"/>
                                
                                <body name="tool_link" pos="0.055 0 0">
                                    <joint name="joint_6" type="hinge" axis="1 0 0" range="-2.53 2.53"/>
                                    <geom type="box" size="0.02 0.035 0.025" rgba="0.2 0.2 0.2 1"/>
                                    
                                    <body name="left_finger" pos="0.02 0.025 0">
                                        <joint name="joint_base_to_left_finger" type="slide" axis="0 -1 0" range="0 0.02"/>
                                        <geom type="box" size="0.02 0.005 0.015" pos="0.02 0 0" rgba="0.9 0.1 0.1 1"/>
                                    </body>

                                    <body name="right_finger" pos="0.02 -0.025 0">
                                        <joint name="joint_base_to_right_finger" type="slide" axis="0 1 0" range="0 0.02"/>
                                        <geom type="box" size="0.02 0.005 0.015" pos="0.02 0 0" rgba="0.9 0.1 0.1 1"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="a_j1" joint="joint_1" kp="100"/>
        <position name="a_j2" joint="joint_2" kp="100"/>
        <position name="a_j3" joint="joint_3" kp="100"/>
        <position name="a_j4" joint="joint_4" kp="100"/>
        <position name="a_j5" joint="joint_5" kp="100"/>
        <position name="a_j6" joint="joint_6" kp="100"/>
        <position name="a_finger_l" joint="joint_base_to_left_finger" kp="500"/>
        <position name="a_finger_r" joint="joint_base_to_right_finger" kp="500"/>
    </actuator>
</mujoco>